APP_NAME="Adam Travel"
APP_VERSION=2.4.1
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=adam_travel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
AUTH_OTP_EXPIRE_MINUTES=10
AUTH_OTP_MAX_ATTEMPTS=5

BROADCAST_CONNECTION=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap2
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
ABLY_KEY=
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FIREBASE_PROJECT_ID=
FIREBASE_PROJECT_IDS=

BILLING_PROVIDER=revenuecat
REVENUECAT_WEBHOOK_SECRET=
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LOCATION_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
LOCATION_SUGGESTIONS_DEBUG_ENABLED=true
LOCATION_SUGGESTIONS_SUBMIT_PER_MINUTE=20
LOCATION_SUGGESTIONS_SUBMIT_PER_HOUR=100
LOCATION_SUGGESTIONS_STATUS_POLLS_PER_MINUTE=120
LOCATION_SUGGESTIONS_OPENAI_VIDEO_CHUNK_SIZE=8
LOCATION_SUGGESTIONS_OPENAI_SINGLE_VIDEO_IMAGE_DETAIL=high
LOCATION_SUGGESTIONS_OPENAI_CHUNKED_VIDEO_IMAGE_DETAIL=low
LOCATION_SUGGESTIONS_ASYNC_ENABLED=true
LOCATION_SUGGESTIONS_ASYNC_TTL_MINUTES=1440
LOCATION_SUGGESTIONS_AUTO_ROUTE_LONG_VIDEOS=true
LOCATION_SUGGESTIONS_AUTO_ROUTE_VIDEO_SECONDS=45
LOCATION_SUGGESTIONS_VIDEO_ENABLED=true
LOCATION_SUGGESTIONS_FRAME_DIVISOR_SECONDS=2
LOCATION_SUGGESTIONS_MAX_VIDEO_SECONDS=45
LOCATION_SUGGESTIONS_FRAME_INTERVAL_SECONDS=3
LOCATION_SUGGESTIONS_MAX_FRAMES=8
YTDLP_PATH=
YTDLP_COOKIES_PATH=
YTDLP_JS_RUNTIMES=
FFMPEG_PATH=

VITE_APP_NAME="${APP_NAME}"
