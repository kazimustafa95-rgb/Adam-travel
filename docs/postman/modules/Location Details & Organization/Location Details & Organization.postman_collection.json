                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"location\": {\n        \"name\": \"Senso-ji Temple\",\n        \"category\": \"activity\",\n        \"city\": \"Tokyo\",\n        \"country_code\": \"JP\",\n        \"latitude\": 35.7148,\n        \"longitude\": 139.7967,\n        \"provider_source\": \"manual\"\n    },\n    \"category\": \"activity\",\n    \"title_override\": \"Must Visit Temple\",\n    \"notes\": \"Historic temple stop for day one.\",\n    \"region_label\": \"Japan 2027\",\n    \"is_favorite\": true,\n    \"visibility\": \"private\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const saved_place_id = json[\"data\"][\"id\"];",
                            "    if (saved_place_id !== undefined && saved_place_id !== null) {",
                            "        pm.collectionVariables.set(\"saved_place_id\", String(saved_place_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
