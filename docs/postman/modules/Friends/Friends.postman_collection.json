        {
            "name": "Send Friend Request",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/friends/requests",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "friends",
                        "requests"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"recipient_email\": \"friend@example.com\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const friend_request_id = json[\"data\"][\"id\"];",
                            "    if (friend_request_id !== undefined && friend_request_id !== null) {",
                            "        pm.collectionVariables.set(\"friend_request_id\", String(friend_request_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Cancel Friend Request",
            "request": {
                "method": "DELETE",
                "header": [
                    {
