                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "trips",
                        "{{trip_id}}",
                        "suggestions",
                        "generate"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"limit\": 3,\n    \"force_refresh\": false\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const suggestion_id = json[\"data\"][0][\"id\"];",
                            "    if (suggestion_id !== undefined && suggestion_id !== null) {",
                            "        pm.collectionVariables.set(\"suggestion_id\", String(suggestion_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
