    "item": [
        {
            "name": "Add Trip Pool Place",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/trips/{{trip_id}}/pool",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "trips",
                        "{{trip_id}}",
                        "pool"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"saved_place_id\": \"{{saved_place_id}}\",\n    \"trip_category\": \"activity\",\n    \"notes\": \"Great sunset option\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const trip_place_id = json[\"data\"][\"id\"];",
                            "    if (trip_place_id !== undefined && trip_place_id !== null) {",
                            "        pm.collectionVariables.set(\"trip_place_id\", String(trip_place_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
        },
