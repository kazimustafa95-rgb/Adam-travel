                    "raw": "{\n    \"email\": \"friend@example.com\",\n    \"role\": \"editor\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const invite_id = json[\"data\"][\"id\"];",
                            "    if (invite_id !== undefined && invite_id !== null) {",
                            "        pm.collectionVariables.set(\"invite_id\", String(invite_id));",
                            "    }",
                            "    const trip_invite_token = json[\"data\"][\"token\"];",
                            "    if (trip_invite_token !== undefined && trip_invite_token !== null) {",
                            "        pm.collectionVariables.set(\"trip_invite_token\", String(trip_invite_token));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
