        {
            "name": "Accept Trip Invitation",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/profile/invitations/trips/{{invite_id}}/accept",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "profile",
                        "invitations",
                        "trips",
                        "{{invite_id}}",
                        "accept"
                    ]
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const trip_id = json[\"data\"][\"id\"];",
                            "    if (trip_id !== undefined && trip_id !== null) {",
                            "        pm.collectionVariables.set(\"trip_id\", String(trip_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
        },
