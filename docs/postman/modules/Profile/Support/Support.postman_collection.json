                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"subject\": \"Need help with offline maps\",\n    \"message\": \"My offline package is missing after reinstalling the app.\",\n    \"priority\": \"high\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const support_ticket_id = json[\"data\"][\"id\"];",
                            "    if (support_ticket_id !== undefined && support_ticket_id !== null) {",
                            "        pm.collectionVariables.set(\"support_ticket_id\", String(support_ticket_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
