    "item": [
        {
            "name": "Create Import",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/imports",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "imports"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"raw_text\": \"Place: Senso-ji Temple. City: Tokyo. Country: JP. Category: activity. Coordinates: 35.7148, 139.7967. Historic temple district with a lively market street.\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const import_id = json[\"data\"][\"id\"];",
                            "    if (import_id !== undefined && import_id !== null) {",
                            "        pm.collectionVariables.set(\"import_id\", String(import_id));",
                            "    }",
                            "    const import_candidate_id = json[\"data\"][\"candidates\"][0][\"id\"];",
                            "    if (import_candidate_id !== undefined && import_candidate_id !== null) {",
                            "        pm.collectionVariables.set(\"import_candidate_id\", String(import_candidate_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Show Import",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
