    "item": [
        {
            "name": "Register",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/auth/register",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "register"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Jamie Traveler\",\n    \"email\": \"jamie@example.com\",\n    \"password\": \"securePass123!\",\n    \"password_confirmation\": \"securePass123!\",\n    \"device_name\": \"{{device_name}}\",\n    \"device_platform\": \"{{device_platform}}\",\n    \"device_identifier\": \"{{device_identifier}}\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "auth": {
                    "type": "noauth"
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const access_token = json[\"data\"][\"token\"];",
                            "    if (access_token !== undefined && access_token !== null) {",
                            "        pm.collectionVariables.set(\"access_token\", String(access_token));",
                            "    }",
                            "    const user_id = json[\"data\"][\"user\"][\"id\"];",
                            "    if (user_id !== undefined && user_id !== null) {",
                            "        pm.collectionVariables.set(\"user_id\", String(user_id));",
                            "    }",
                            "    const user_uuid = json[\"data\"][\"user\"][\"uuid\"];",
                            "    if (user_uuid !== undefined && user_uuid !== null) {",
                            "        pm.collectionVariables.set(\"user_uuid\", String(user_uuid));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
        },
