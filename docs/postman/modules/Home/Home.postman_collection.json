            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (pm.response.code >= 200 && pm.response.code < 300) {",
                            "    const json = pm.response.json();",
                            "    const notification_id = json[\"data\"][\"groups\"][0][\"items\"][0][\"id\"];",
                            "    if (notification_id !== undefined && notification_id !== null) {",
                            "        pm.collectionVariables.set(\"notification_id\", String(notification_id));",
                            "    }",
                            "}"
                        ]
                    }
                }
            ]
