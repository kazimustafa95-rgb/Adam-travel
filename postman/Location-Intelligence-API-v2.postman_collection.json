						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"input\": \"Lucky One Mall Karachi\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v2/location-intelligence/resolve",
							"host": ["{{base_url}}"],
							"path": ["api", "v2", "location-intelligence", "resolve"]
						},
						"description": "Sends a plain-text place name.\nDetected type → text\nFlow: Google Places Text Search API"
					},
					"response": [
						{
							"name": "200 Success - Place Found",
							"originalRequest": {
								"method": "POST",
								"header": [
									{"key": "Content-Type", "value": "application/json"},
