							"_postman_previewlanguage": "json",
							"body": "{\n    \"success\": true,\n    \"type\": \"text\",\n    \"resolved_place\": {\n        \"id\": \"ChIJXxxxxxxxxxxxxxx\",\n        \"name\": \"LuckyOne Mall\",\n        \"address\": \"Gulshan-e-Iqbal, Karachi, Karachi City, Sindh, Pakistan\",\n        \"lat\": 24.9321,\n        \"lng\": 67.1023,\n        \"confidence\": 90\n    },\n    \"signals\": {\n        \"query\": \"Lucky One Mall Karachi\"\n    }\n}"
