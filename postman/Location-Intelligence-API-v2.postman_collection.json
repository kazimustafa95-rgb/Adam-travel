{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Location Intelligence API v2",
		"description": "Standalone Google-powered intelligent location detection API.\n\nEndpoint: POST /api/v2/location-intelligence/resolve\n\nSupports four input types:\n1. Plain text (place name / search query)\n2. Image URL (Google Vision — landmark, OCR, label detection)\n3. Video URL (YouTube/Vimeo via thumbnail + Vision; direct .mp4 via Video Intelligence API)\n4. Social/blog/public post URL (Open Graph scraping + Vision on og:image)\n\nBase URL variable: {{base_url}} — set this to your server, e.g. http://localhost:8000",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string",
			"description": "Change this to your Laravel app URL"
		}
	],
	"item": [
		{
			"name": "1. Text Input",
