								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"input\": \"Lucky One Mall Karachi\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/v2/location-intelligence/resolve",
									"host": ["{{base_url}}"],
									"path": ["api", "v2", "location-intelligence", "resolve"]
								}
							},
							"status": "OK",
